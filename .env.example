# ============================================================
# Møgspar — environment variables
# ============================================================
# Copy this file to .env and fill in all values.
# NEVER commit .env to git — it contains secrets.
# ============================================================

# ------------------------------------------------------------
# SECURITY — required, no defaults
# ------------------------------------------------------------

# Secret key used to sign JWT tokens.
# Generate a strong one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-real-secret-key

# How long a login session lasts (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# If you want the app to have an invite key, place it here. If this is removed, the requirement for an invite key as also removed in the app.
INVITE_CODE=replace-with-invite-key


# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------

# SQLite for development. For production on the Pi, keep this
# or switch to postgresql://user:password@host/dbname
DATABASE_URL=sqlite:///./mogspar.db

# ------------------------------------------------------------
# CORS — which frontend origins the backend will accept
# ------------------------------------------------------------

# Development: the Vite dev server
ALLOWED_ORIGINS=http://localhost:5173

# ------------------------------------------------------------
# REGISTRATION — optional invite code
# ------------------------------------------------------------

# If set, users must enter this code to create an account.
# Leave empty for open registration.
INVITE_CODE=
