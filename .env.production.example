# ============================================================
# Møgspar — PRODUCTION environment variables
# Copy to .env and fill in all values before deploying.
# NEVER commit .env to git.
# ============================================================

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=insert-key

ACCESS_TOKEN_EXPIRE_MINUTES=120

# SQLite path — stored in the mogspar_db Docker volume
DATABASE_URL=sqlite:////app/data/mogspar.db

# Your domain — must match what is in nginx/nginx.conf
ALLOWED_ORIGINS=https://YOUR_DOMAIN

# Optional: require an invite code for new registrations
INVITE_CODE=
